        listening = true
        disp.Text = "[ PRESS KEY... ]"
        disp.TextColor3 = C.Warn
        local conn
        conn = UserInputService.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.Keyboard then
