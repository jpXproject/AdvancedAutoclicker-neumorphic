-- ─── Helper: neumorphic card ───────────────────
local function NCard(parent, x, y, w, h, label)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0, w, 0, h)
    card.Position = UDim2.new(0, x, 0, y)
    card.BackgroundColor3 = C.Raised
    card.BorderSizePixel = 0
    card.ZIndex = parent.ZIndex + 1
    card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)

    if label and label ~= "" then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -16, 0, 18)
        lbl.Position = UDim2.new(0, 12, 0, 8)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.TextColor3 = C.AccentDim
        lbl.TextSize = 10
        lbl.Font = Enum.Font.GothamBold
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.ZIndex = card.ZIndex + 1
        lbl.Parent = card
    end
    return card
end

-- ─── Helper: neumorphic text input ─────────────
local function NInput(parent, x, y, w, h, def, numOnly)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, w, 0, h)
    bg.Position = UDim2.new(0, x, 0, y)
    bg.BackgroundColor3 = C.Pressed
    bg.BorderSizePixel = 0
    bg.ZIndex = parent.ZIndex + 1
    bg.Parent = parent
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 8)

    local inp = Instance.new("TextBox")
    inp.Size = UDim2.new(1, -10, 1, 0)
    inp.Position = UDim2.new(0, 5, 0, 0)
    inp.BackgroundTransparency = 1
    inp.Text = tostring(def or "0")
    inp.TextColor3 = C.AccentGlow
    inp.TextSize = 13
    inp.Font = Enum.Font.GothamBold
    inp.TextXAlignment = Enum.TextXAlignment.Center
    inp.ClearTextOnFocus = false
    inp.ZIndex = bg.ZIndex + 1
    inp.Parent = bg

    if numOnly then
        inp.FocusLost:Connect(function()
            local n = tonumber(inp.Text)
            if not n then inp.Text = tostring(def or "0") end
        end)
    end
    return inp
end

-- ─── Helper: neumorphic toggle button ──────────
local function NToggle(parent, x, y, w, h, textOff, textOn, callback)
    local active = false
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, w, 0, h)
    btn.Position = UDim2.new(0, x, 0, y)
    btn.BackgroundColor3 = C.Raised
    btn.BorderSizePixel = 0
    btn.Text = textOff
    btn.TextColor3 = C.TextSec
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = parent.ZIndex + 1
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)

    btn.MouseButton1Click:Connect(function()
        active = not active
        if active then
            Tween(btn, {BackgroundColor3 = C.Accent, TextColor3 = C.Base}, 0.18)
            btn.Text = textOn
        else
            Tween(btn, {BackgroundColor3 = C.Raised, TextColor3 = C.TextSec}, 0.18)
            btn.Text = textOff
        end
        if callback then callback(active) end
    end)
    return btn, function() return active end
end

-- ─── Helper: radio group ───────────────────────
local function NRadioGroup(parent, options, defaultIdx, x, startY, gap, callback)
    local selected = defaultIdx or 1
    local dots = {}
    for i, opt in ipairs(options) do
        local row = Instance.new("Frame")
        row.Size = UDim2.new(0, 120, 0, 22)
        row.Position = UDim2.new(0, x, 0, startY + (i-1)*gap)
        row.BackgroundTransparency = 1
        row.ZIndex = parent.ZIndex + 1
        row.Parent = parent

        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 14, 0, 14)
        dot.Position = UDim2.new(0, 0, 0.5, -7)
        dot.BackgroundColor3 = i == selected and C.Accent or C.TextDim
        dot.BorderSizePixel = 0
        dot.ZIndex = row.ZIndex + 1
        dot.Parent = row
        Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

        local inner = Instance.new("Frame")
        inner.Size = UDim2.new(0, 6, 0, 6)
        inner.Position = UDim2.new(0.5, -3, 0.5, -3)
        inner.BackgroundColor3 = C.Base
        inner.BorderSizePixel = 0
        inner.Visible = i == selected
        inner.ZIndex = dot.ZIndex + 1
        inner.Parent = dot
        Instance.new("UICorner", inner).CornerRadius = UDim.new(1, 0)

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -20, 1, 0)
        lbl.Position = UDim2.new(0, 20, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = opt
        lbl.TextColor3 = C.TextPri
        lbl.TextSize = 11
        lbl.Font = Enum.Font.Gotham
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.ZIndex = row.ZIndex + 1
        lbl.Parent = row

        table.insert(dots, {dot=dot, inner=inner})

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.ZIndex = row.ZIndex + 2
        btn.Parent = row
        btn.MouseButton1Click:Connect(function()
            selected = i
            for j, d in ipairs(dots) do
                local sel = j == i
                Tween(d.dot, {BackgroundColor3 = sel and C.Accent or C.TextDim}, 0.15)
                d.inner.Visible = sel
            end
            if callback then callback(i, opt) end
        end)
    end
end

