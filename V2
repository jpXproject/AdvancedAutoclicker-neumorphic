local function SelectTab(name)
    State.currentTab = name
    for _, t in pairs(TabButtons) do
        local active = t.Name == name
        Tween(t, {
            BackgroundColor3 = active and C.Accent or C.TabInact,
            TextColor3 = active and C.Base or C.TextSec
        }, 0.18)
    end
    -- show/hide pages
    for _, child in ipairs(Main:GetChildren()) do
        if child:IsA("ScrollingFrame") or (child:IsA("Frame") and child.Name:sub(1,4) == "Page") then
            child.Visible = child.Name == "Page"..name
        end
    end
end

