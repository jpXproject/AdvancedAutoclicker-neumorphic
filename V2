-- ════════════════════════════════════════════════
--  MAIN LOOP
-- ════════════════════════════════════════════════
local lastClick   = 0
local lastAfk     = tick()
local lastCpsSample = tick()
local cpsCount    = 0

local loopConn = RunService.Heartbeat:Connect(function(dt)
    local now = tick()

    -- Read interval
    local hr  = tonumber(InpHr.Text)  or 0
    local mn  = tonumber(InpMin.Text) or 0
    local sec = tonumber(InpSec.Text) or 0
    local ms  = tonumber(InpMs.Text)  or 20
    State.clickInterval = hr*3600 + mn*60 + sec + ms/1000
    if State.clickInterval < 0.001 then State.clickInterval = 0.001 end

    -- Clicker
    if State.clickActive and (now - lastClick) >= State.clickInterval then
        if State.repeatMode == "Count" then
            State.repeatCount = tonumber(InpCount.Text) or 10
            if State.clicksDone >= State.repeatCount then
                ToggleClicker()
                return
            end
        end
        PerformClick()
        lastClick = now
        cpsCount = cpsCount + 1
    end

    -- Macro playback
    if State.playing and #State.recordedClicks > 0 then
        local ev = State.recordedClicks[State.playIndex]
        if ev and (now - lastClick) >= State.clickInterval then
            if State.clickButton == "Left" then mouse1click()
            elseif State.clickButton == "Right" then mouse2click()
            else mouse3click() end
            State.playIndex = State.playIndex + 1
            if State.playIndex > #State.recordedClicks then
                State.playing = false
                RecStatus.Text = "✔ PLAYBACK DONE"
                RecStatus.TextColor3 = C.Green
            end
            lastClick = now
        end
    end

    -- CPS calculation (per second)
    if (now - lastCpsSample) >= 1 then
        StatCPS.Text   = cpsCount.."\nCPS"
        cpsCount       = 0
        lastCpsSample  = now
        StatTotal.Text = State.totalClicks.."\nTOTAL"
        StatTime.Text  = (os.time()-State.sessionStart).."s\nSESSION"
    end

    -- Anti-AFK
    if State.antiAfkActive and (now - lastAfk) >= 60 then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then hum.Jump = true end
        end
        lastAfk = now
    end

    -- Noclip
    if State.noclip then
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end

    -- Cursor viz
    local m = LocalPlayer:GetMouse()
    VisPosLabel.Text = "X: "..m.X.."  Y: "..m.Y
    local vw = VisFrame.AbsoluteSize.X
    local vh = VisFrame.AbsoluteSize.Y
    local sx = game.Workspace.CurrentCamera.ViewportSize.X
    local sy = game.Workspace.CurrentCamera.ViewportSize.Y
    if sx > 0 and sy > 0 then
        VisCursor.Position = UDim2.new(m.X/sx, -7, m.Y/sy, -7)
    end
end)

