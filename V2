-- ════════════════════════════════════════════════
--  CLICK LOGIC
-- ════════════════════════════════════════════════
local function PerformClick()
    local mouse = LocalPlayer:GetMouse()
    local x = State.posMode == "Fixed" and State.fixedX or mouse.X
    local y = State.posMode == "Fixed" and State.fixedY or mouse.Y

    local times = State.clickType == "Single" and 1
               or State.clickType == "Double" and 2
               or 3

    for _ = 1, times do
        if State.clickButton == "Left" then
            mouse1click()
        elseif State.clickButton == "Right" then
            mouse2click()
        else
            mouse3click()
        end
        if times > 1 then task.wait(0.01) end
    end

    State.totalClicks = State.totalClicks + times
    State.clicksDone  = State.clicksDone  + 1

    -- Recording
    if State.recording then
        table.insert(State.recordedClicks, {x=x, y=y, btn=State.clickButton, t=tick()})
        RecCount.Text = "Recorded: "..#State.recordedClicks.." events"
    end
end

-- ════════════════════════════════════════════════
--  TOGGLE CLICK
-- ════════════════════════════════════════════════
local function ToggleClicker()
    State.clickActive = not State.clickActive
    State.clicksDone  = 0

    if State.clickActive then
        Tween(BigBtn,      {BackgroundColor3 = C.Accent},    0.2)
        Tween(BigBtnGlow,  {BackgroundTransparency = 0.6},   0.2)
        BigBtnIcon.TextColor3 = C.Base
        BigBtnLabel.TextColor3 = C.Base
        BigBtnIcon.Text  = "⏹"
        BigBtnLabel.Text = "STOP"
        StatusDot.BackgroundColor3   = C.Green
        StatusLabel.Text             = "ACTIVE"
        StatusLabel.TextColor3       = C.Green
    else
        Tween(BigBtn,      {BackgroundColor3 = C.Raised},    0.2)
        Tween(BigBtnGlow,  {BackgroundTransparency = 0.85},  0.2)
        BigBtnIcon.TextColor3 = C.Accent
        BigBtnLabel.TextColor3 = C.Accent
        BigBtnIcon.Text  = "▶"
        BigBtnLabel.Text = "START"
        StatusDot.BackgroundColor3   = C.Red
        StatusLabel.Text             = "INACTIVE"
        StatusLabel.TextColor3       = C.Red
    end
end

